#!/bin/bash

# ─────────────────────────────────────────────
#  DNS Switcher — with chattr lock/unlock support
# ─────────────────────────────────────────────

declare -A DNS_SERVERS=(
    ["Shecan"]="178.22.122.100,185.51.200.2"
    ["Shecan Pro"]="178.22.122.101,185.51.200.1"
    ["Begzar"]="185.55.226.26,185.55.225.25"
    ["MCI"]="10.185.68.113,10.185.68.114"
    ["Google"]="8.8.8.8,8.8.4.4"
    ["Cloudflare"]="1.1.1.1"
)

RESOLV_CONF="/etc/resolv.conf"

# ─────────────────────────────────────────────
#  Display
# ─────────────────────────────────────────────

display_dns_list() {
    echo "Available DNS Servers:"
    local i=1
    for dns_name in "${!DNS_SERVERS[@]}"; do
        echo "  $i. $dns_name (${DNS_SERVERS[$dns_name]})"
        ((i++))
    done
}

# ─────────────────────────────────────────────
#  Selection
# ─────────────────────────────────────────────

get_dns_name_by_index() {
    local target_index="$1"
    local i=1
    for dns_name in "${!DNS_SERVERS[@]}"; do
        if ((i == target_index)); then
            echo "$dns_name"
            return 0
        fi
        ((i++))
    done
    return 1
}

validate_selection() {
    local input="$1"

    if [[ $input =~ ^[0-9]+$ ]]; then
        get_dns_name_by_index "$input"
        return $?
    fi

    if [[ -n "${DNS_SERVERS[$input]}" ]]; then
        echo "$input"
        return 0
    fi

    return 1
}

select_dns() {
    local input selected_name

    while true; do
        read -rp "Select a DNS server (name or number): " input
        selected_name=$(validate_selection "$input")

        if [[ $? -eq 0 && -n "$selected_name" ]]; then
            echo "$selected_name"
            return 0
        fi

        echo "Invalid selection. Please try again." >&2
    done
}

# ─────────────────────────────────────────────
#  File lock / unlock
# ─────────────────────────────────────────────

is_file_immutable() {
    lsattr "$RESOLV_CONF" 2>/dev/null | grep -q '\-i\-'
}

unlock_resolv_conf() {
    if is_file_immutable; then
        echo "Unlocking $RESOLV_CONF (removing immutable flag)..."
        sudo chattr -i "$RESOLV_CONF"
    fi
}

lock_resolv_conf() {
    echo "Locking $RESOLV_CONF (setting immutable flag)..."
    sudo chattr +i "$RESOLV_CONF"
}

# ─────────────────────────────────────────────
#  Write DNS
# ─────────────────────────────────────────────

write_dns_entries() {
    local dns_string="$1"

    sudo bash -c "echo '' > $RESOLV_CONF"

    IFS=',' read -ra dns_array <<< "$dns_string"
    for dns in "${dns_array[@]}"; do
        echo "nameserver $dns" | sudo tee -a "$RESOLV_CONF" > /dev/null
    done
}

apply_dns() {
    local selected_name="$1"
    local dns_string="${DNS_SERVERS[$selected_name]}"

    unlock_resolv_conf
    write_dns_entries "$dns_string"
    lock_resolv_conf

    echo "Done. Applied DNS servers for '$selected_name': $dns_string"
}

# ─────────────────────────────────────────────
#  Main
# ─────────────────────────────────────────────

main() {
    display_dns_list
    local selected_name
    selected_name=$(select_dns)
    apply_dns "$selected_name"
}

main