#!/bin/bash

# ─────────────────────────────────────────────
#  DNS Switcher
# ─────────────────────────────────────────────

declare -A DNS_SERVERS=(
    ["LOCAL"]="127.0.0.1"
    ["MCI"]="10.185.68.113,10.185.68.114"
    ["IRANCELL"]="10.255.255.254,10.10.10.10"
    ["SHECAN"]="178.22.122.100,185.51.200.2"
    ["SHECAN PRO"]="178.22.122.100,185.51.200.2"
    ["GOOGLE"]="8.8.8.8,8.8.4.4"
    ["CF"]="1.1.1.1"
)

RESOLV_CONF="/etc/resolv.conf"

# ─────────────────────────────────────────────
#  Helpers
# ─────────────────────────────────────────────

info()    { echo "[*] $*"; }
success() { echo "[✓] $*"; }
warn()    { echo "[!] $*" >&2; }
die()     { echo "[✗] $*" >&2; exit 1; }

require_root() {
    [[ $EUID -eq 0 ]] && return
    info "Re-launching with root privileges..."
    exec sudo bash "$0" "$@"
}

# ─────────────────────────────────────────────
#  systemd-resolved conflict check
# ─────────────────────────────────────────────

check_resolved_conflict() {
    systemctl is-active --quiet systemd-resolved || return 0

    echo ""
    echo "  ╔══════════════════════════════════════╗"
    echo "  ║  ⚠  systemd-resolved is active!      ║"
    echo "  ╚══════════════════════════════════════╝"
    echo ""
    warn "systemd-resolved is running and controls /etc/resolv.conf."
    warn "It will override any changes this script makes."
    echo ""
    echo "  To fix this permanently, run:"
    echo "    sudo systemctl disable --now systemd-resolved"
    echo "    sudo systemctl stop systemd-resolved"
    echo "    sudo systemctl mask systemd-resolved"
    echo "    sudo pacman -Rns netctl"
    echo ""
    read -rp "  Continue anyway? [y/N]: " ans
    [[ "${ans,,}" == "y" ]] || die "Aborted."
    echo ""
}

# ─────────────────────────────────────────────
#  Display & Selection
# ─────────────────────────────────────────────

display_dns_list() {
    echo -e "\n  Available DNS Servers"
    echo "  ──────────────────────────────────────"
    local i=1
    for name in "${!DNS_SERVERS[@]}"; do
        printf "  %2d.  %-14s  %s\n" "$i" "$name" "${DNS_SERVERS[$name]}"
        ((i++))
    done
    echo -e "  ──────────────────────────────────────\n"
}

get_name_by_index() {
    local idx=1
    for name in "${!DNS_SERVERS[@]}"; do
        ((idx++ == $1)) && echo "$name" && return 0
    done
    return 1
}

select_dns() {
    local input name
    while true; do
        read -rp "  Select DNS (name or number): " input
        if [[ $input =~ ^[0-9]+$ ]]; then
            name=$(get_name_by_index "$input")
        elif [[ -n "${DNS_SERVERS[$input]}" ]]; then
            name="$input"
        fi
        [[ -n "$name" ]] && echo "$name" && return
        warn "Invalid selection, try again."
        name=""
    done
}

# ─────────────────────────────────────────────
#  resolv.conf management
# ─────────────────────────────────────────────

is_immutable() {
    lsattr "$RESOLV_CONF" 2>/dev/null | awk '{print $1}' | grep -q 'i'
}

prepare_resolv_conf() {
    if [[ -L "$RESOLV_CONF" ]]; then
        info "$RESOLV_CONF is a symlink — replacing with a real file..."
        rm -f "$RESOLV_CONF"
    fi

    if [[ ! -f "$RESOLV_CONF" ]]; then
        info "$RESOLV_CONF not found — creating..."
        touch "$RESOLV_CONF" || die "Cannot create $RESOLV_CONF."
    fi

    is_immutable && { info "Unlocking $RESOLV_CONF..."; chattr -i "$RESOLV_CONF" || die "Failed to unlock."; }
}

write_resolv_conf() {
    local name="$1" ips="$2"
    {
        echo "# dns-switcher — profile: $name"
        echo "# updated: $(date '+%Y-%m-%d %H:%M:%S')"
        echo ""
        echo "search ."
        echo ""
        IFS=',' read -ra arr <<< "$ips"
        printf "nameserver %s\n" "${arr[@]}"
    } > "$RESOLV_CONF" || die "Failed to write $RESOLV_CONF."
}

lock_resolv_conf() {
    chattr +i "$RESOLV_CONF" || die "Failed to lock $RESOLV_CONF."
    info "Locked $RESOLV_CONF."
}

# ─────────────────────────────────────────────
#  nmcli — detect active connection
# ─────────────────────────────────────────────

get_active_connection() {
    # Returns the name of the first active non-loopback nmcli connection
    nmcli -t -f NAME,TYPE,STATE connection show --active \
        | grep -v ':loopback:' \
        | awk -F: '$3 == "activated" { print $1; exit }'
}

apply_nmcli_dns() {
    local conn="$1" ips="$2"

    # Convert comma-separated IPs to space-separated for nmcli
    local nmcli_dns
    nmcli_dns=$(echo "$ips" | tr ',' ' ')

    if ! command -v nmcli &>/dev/null; then
        warn "nmcli not found — skipping NetworkManager update."
        return 0
    fi

    if [[ -z "$conn" ]]; then
        warn "No active NetworkManager connection found — skipping nmcli update."
        return 0
    fi

    info "Applying DNS to NetworkManager connection: '$conn'..."

    nmcli connection modify "$conn" ipv4.dns "$nmcli_dns" \
        || die "nmcli: failed to set DNS on '$conn'."

    # Ensure NM doesn't override DNS from DHCP
    nmcli connection modify "$conn" ipv4.ignore-auto-dns yes \
        || warn "nmcli: could not set ignore-auto-dns (non-fatal)."

    info "Restarting connection '$conn'..."
    nmcli connection down "$conn" \
        || warn "nmcli: failed to bring down '$conn' (may already be down)."
    nmcli connection up "$conn" \
        || die "nmcli: failed to bring up '$conn'."

    success "NetworkManager updated and connection restarted."
}

# ─────────────────────────────────────────────
#  Apply
# ─────────────────────────────────────────────

apply_dns() {
    local name="$1" ips="${DNS_SERVERS[$1]}"

    # ── resolv.conf ──
    prepare_resolv_conf
    write_resolv_conf "$name" "$ips"
    lock_resolv_conf

    # ── nmcli ──
    local conn
    conn=$(get_active_connection)
    apply_nmcli_dns "$conn" "$ips"

    echo ""
    success "Applied '$name' → $ips"
    [[ -n "$conn" ]] && success "Interface '$conn' updated and restarted."
    echo -e "\n  $RESOLV_CONF now contains:"
    echo "  ──────────────────────────────────────"
    sed 's/^/  /' "$RESOLV_CONF"
    echo -e "  ──────────────────────────────────────\n"
}

# ─────────────────────────────────────────────
#  Main
# ─────────────────────────────────────────────

main() {
    require_root
    check_resolved_conflict
    display_dns_list
    apply_dns "$(select_dns)"
}

main