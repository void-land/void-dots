client
dev tun
remote ir.de2.e-mix.ir 1403 udp
tun-mtu 1500
tls-client
nobind
persist-tun
persist-key
mute-replay-warnings
verb 3
cipher AES-128-GCM
redirect-gateway def1
auth SHA1
pull
auth-user-pass
connect-retry 1
reneg-sec 3600
remote-cert-tls server
<ca>
